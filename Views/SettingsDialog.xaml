<Window x:Class="ContractManager.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置" Height="420" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="设置" Style="{StaticResource HeadingStyle}" Margin="0,0,0,16"/>

        <!-- Tabs -->
        <TabControl Grid.Row="1">
            <!-- File Storage Tab -->
            <TabItem Header="文件存储">
                <StackPanel Margin="12">
                    <TextBlock Text="存储路径" Style="{StaticResource FormLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="StoragePathTextBox" Style="{StaticResource FormTextBoxStyle}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览..." Style="{StaticResource ToolbarButtonStyle}"
                                Click="BrowseStoragePathButton_Click" Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock Text="留空使用默认目录 (%APPDATA%/ContractManager/attachments)"
                               FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>

                    <TextBlock Text="默认提醒天数" Style="{StaticResource FormLabelStyle}" Margin="0,16,0,0"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DefaultReminderDaysSlider"
                                Minimum="1" Maximum="365" Value="90"
                                TickFrequency="30" IsSnapToTickEnabled="False"/>
                        <TextBox Grid.Column="1"
                                Text="{Binding ElementName=DefaultReminderDaysSlider, Path=Value, StringFormat=F0}"
                                Style="{StaticResource FormTextBoxStyle}"
                                TextAlignment="Center" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <!-- WeChat Webhook Tab -->
            <TabItem Header="企业微信通知">
                <StackPanel Margin="12">
                    <CheckBox x:Name="WebhookEnabledCheckBox" Content="启用 Webhook 通知" Margin="0,0,0,12"/>

                    <TextBlock Text="Webhook URL" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="WebhookUrlTextBox" Style="{StaticResource FormTextBoxStyle}"
                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"/>

                    <Button Content="测试连接" Style="{StaticResource PrimaryButtonStyle}"
                            Click="TestWebhookButton_Click"
                            HorizontalAlignment="Left" Margin="0,12,0,0"/>
                    <TextBlock x:Name="WebhookTestResult" Margin="0,8,0,0" FontSize="12"/>
                </StackPanel>
            </TabItem>

            <!-- Scheduled Task Tab -->
            <TabItem Header="定时任务">
                <StackPanel Margin="12">
                    <CheckBox x:Name="AutoStartCheckBox" Content="开机自动启动" Margin="0,0,0,12"/>

                    <TextBlock Text="提醒时间 (HH:mm)" Style="{StaticResource FormLabelStyle}"/>
                    <TextBox x:Name="ReminderTimeTextBox" Style="{StaticResource FormTextBoxStyle}"
                             Width="100" HorizontalAlignment="Left"/>
                    <TextBlock Text="Windows 任务计划将在每天指定时间启动程序检查合同到期情况。"
                               FontSize="11" Foreground="#888888" Margin="0,4,0,0" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="注册/更新任务" Style="{StaticResource PrimaryButtonStyle}"
                                Click="RegisterTaskButton_Click"/>
                        <Button Content="取消任务" Style="{StaticResource SecondaryButtonStyle}"
                                Click="UnregisterTaskButton_Click" Margin="8,0,0,0"/>
                    </StackPanel>

                    <TextBlock x:Name="TaskStatusText" Margin="0,12,0,0" FontSize="12"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存" Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click" Width="80"/>
            <Button Content="取消" Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click" Width="80" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>